  [Sand bucket — clean, dry], [1], [For smothering small fires in open vessels. Do not substitute water.],
  [Safety glasses or chemical splash goggles], [1 pair], [Required whenever heat is in use.],
  [Heat-resistant gloves], [1 pair], [For handling hot glassware and crucibles.],
  [Nitrile chemical-resistant gloves — box], [1 box], [For all solvent and mineral salt work. Single-use; replace between sessions.],
  [Dedicated laboratory clothing or apron], [1], [Worn only in the laboratory. Not worn in food preparation areas.],
